rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trips/{tripId} {

      // NEW: helper — is the calling user in the deactivated list?
      function isDeactivated() {
        return 'deactivatedMemberIds' in resource.data &&
               request.auth.uid in resource.data.deactivatedMemberIds;
      }

      allow read: if request.auth != null && (
        request.auth.uid in resource.data.memberIds ||
        request.auth.token.email in resource.data.pendingInviteEmails ||
        (
          resource.data.inviteCodeEnabled == true &&
          !isDeactivated()               // NEW: deactivated users can't browse via code
        )
      );

      allow create: if request.auth != null;

      allow update: if request.auth != null && (
        request.auth.uid in resource.data.memberIds ||
        request.auth.token.email in resource.data.pendingInviteEmails ||
        (
          resource.data.inviteCodeEnabled == true &&
          !isDeactivated() &&            // NEW: deactivated users can't rejoin via code
          request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
          request.resource.data.memberIds.hasAll([request.auth.uid]) &&
          request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
        )
      );

      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.ownerId;

      match /members/{uid} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
        allow create: if request.auth != null && (
          request.auth.uid == uid ||
          request.auth.uid == get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId
        );
        allow update, delete: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
        match /paymentHistory/{eventId} {
          allow read, write: if request.auth != null &&
            request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
        }
      }
      match /supplies/{itemId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
      }
      match /rides/{rideId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
      }
      match /rideRequests/{uid} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
      }
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
      }
      match /history/{eventId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
      }
    }
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
